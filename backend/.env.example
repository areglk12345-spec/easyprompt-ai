# ตัวอย่างไฟล์ตั้งค่า (Environment Variables)
# ให้ copy ไฟล์นี้เปลี่ยนชื่อเป็น .env แล้วแก้ไขค่าให้ถูกต้อง

# คีย์สำหรับใช้งาน Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# ข้อมูลเชื่อมต่อฐานข้อมูล MySQL
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/easyprompt_db

# คีย์ลับสำหรับสร้าง JWT Token (ต้องสุ่มใหม่ใน production)
SECRET_KEY=generate_a_random_secure_string_here
